# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=helipagos
DB_SYNCHRONIZE=false

# Helipagos
HELIPAGOS_BASE_URL=https://sandbox.helipagos.com
HELIPAGOS_BEARER_TOKEN=your-token
HELIPAGOS_TIMEOUT=30000
HELIPAGOS_WEBHOOK_SECRET=
HELIPAGOS_WEBHOOK_SECRET_HEADER=apikey
HELIPAGOS_WEBHOOK_SECRET_REQUIRED=true

# URLs
WEBHOOK_URL=https://your-domain.com/api/payments/webhook
URL_REDIRECT=https://your-domain.com/payment/result

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=1h
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123